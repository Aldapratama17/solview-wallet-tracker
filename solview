<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SolView — Solana Portfolio Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0a0a0f; --card:#16161f; --border:#2a2a3a;
  --sol:#9945FF; --sol2:#14F195; --text:#e8e8f0;
  --muted:#6b6b80; --danger:#ff4d6d;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(153,69,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(153,69,255,0.04) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}
.orb{position:fixed;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(153,69,255,0.1) 0%,transparent 70%);top:-150px;left:-150px;pointer-events:none;z-index:0;animation:drift 8s ease-in-out infinite alternate;}
@keyframes drift{to{transform:translate(80px,60px);}}
.wrap{position:relative;z-index:1;max-width:820px;margin:0 auto;padding:36px 18px 80px;}

/* Header */
header{display:flex;align-items:center;gap:14px;margin-bottom:44px;}
.logo{width:44px;height:44px;background:linear-gradient(135deg,var(--sol),var(--sol2));border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-weight:700;font-size:15px;color:#fff;flex-shrink:0;}
.brand h1{font-size:22px;font-weight:800;letter-spacing:-0.5px;}
.brand p{font-size:12px;color:var(--muted);font-family:'Space Mono',monospace;}
.badge{margin-left:auto;background:rgba(20,241,149,0.1);border:1px solid rgba(20,241,149,0.3);color:var(--sol2);font-size:11px;font-family:'Space Mono',monospace;padding:4px 12px;border-radius:20px;}

/* Search */
.sbox{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:20px 22px;margin-bottom:16px;transition:border-color .2s;}
.sbox:focus-within{border-color:var(--sol);box-shadow:0 0 0 3px rgba(153,69,255,0.1);}
.slabel{font-size:11px;font-family:'Space Mono',monospace;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:10px;}
.srow{display:flex;gap:10px;align-items:center;}
.srow input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:'Space Mono',monospace;font-size:13px;caret-color:var(--sol2);}
.srow input::placeholder{color:var(--muted);}
.btn{background:linear-gradient(135deg,var(--sol),#7b2fff);border:none;color:#fff;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;padding:10px 20px;border-radius:10px;cursor:pointer;white-space:nowrap;flex-shrink:0;transition:opacity .2s,transform .1s;}
.btn:hover{opacity:.85;} .btn:active{transform:scale(.97);} .btn:disabled{opacity:.4;cursor:not-allowed;}
.demos{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;align-items:center;}
.demos span{font-size:11px;color:var(--muted);font-family:'Space Mono',monospace;}
.chip{background:rgba(153,69,255,0.08);border:1px solid rgba(153,69,255,0.2);color:var(--muted);font-size:11px;font-family:'Space Mono',monospace;padding:4px 12px;border-radius:20px;cursor:pointer;transition:all .2s;}
.chip:hover{background:rgba(153,69,255,0.18);color:var(--text);border-color:var(--sol);}

/* Alerts */
.err{background:rgba(255,77,109,0.08);border:1px solid rgba(255,77,109,0.3);color:var(--danger);font-family:'Space Mono',monospace;font-size:12px;padding:14px 16px;border-radius:12px;margin-bottom:18px;display:none;line-height:1.7;}

/* Loading */
.loading{display:none;text-align:center;padding:60px 0;}
.spin{width:38px;height:38px;border:3px solid var(--border);border-top-color:var(--sol);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 14px;}
@keyframes spin{to{transform:rotate(360deg);}}
.loading p{color:var(--muted);font-family:'Space Mono',monospace;font-size:12px;}

/* Dashboard */
#dash{display:none;}
.whead{display:flex;align-items:center;gap:12px;margin-bottom:26px;flex-wrap:wrap;}
.wav{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--sol),var(--sol2));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:17px;flex-shrink:0;}
.winfo h2{font-size:15px;font-weight:700;}
.waddr{font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);word-break:break-all;}
.rbtn{margin-left:auto;background:var(--card);border:1px solid var(--border);color:var(--muted);font-size:18px;width:38px;height:38px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.rbtn:hover{border-color:var(--sol);color:var(--sol);}

/* Stats */
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:14px;margin-bottom:26px;}
.sc{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:18px 20px;position:relative;overflow:hidden;animation:up .4s ease both;}
.sc:nth-child(2){animation-delay:.07s;} .sc:nth-child(3){animation-delay:.14s;}
@keyframes up{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--sol),var(--sol2));opacity:.6;}
.slb{font-size:11px;font-family:'Space Mono',monospace;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.sv{font-size:24px;font-weight:800;letter-spacing:-1px;line-height:1;}
.sv.g{color:var(--sol2);}
.ss{font-size:12px;color:var(--muted);font-family:'Space Mono',monospace;margin-top:4px;}

/* Section */
.sec{margin-bottom:26px;animation:up .4s ease .18s both;}
.stitle{font-size:12px;font-family:'Space Mono',monospace;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.stitle::after{content:'';flex:1;height:1px;background:var(--border);}

/* Rows */
.tlist,.xlist{display:flex;flex-direction:column;gap:8px;}
.trow{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:13px 16px;display:flex;align-items:center;gap:12px;transition:border-color .2s;}
.trow:hover{border-color:rgba(153,69,255,.4);}
.ticon{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#222230,#1a1a28);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--sol);flex-shrink:0;font-family:'Space Mono',monospace;}
.tname{font-weight:600;font-size:14px;}
.tmint{font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);}
.tamt{margin-left:auto;text-align:right;}
.tamtv{font-family:'Space Mono',monospace;font-size:13px;font-weight:700;}
.tvlink a{color:var(--sol);text-decoration:none;font-size:10px;font-family:'Space Mono',monospace;}

.xrow{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:11px 14px;display:flex;align-items:center;gap:10px;}
.xdot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.xdot.ok{background:var(--sol2);} .xdot.fail{background:var(--danger);}
.xsig{font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);}
.xtime{font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);}
.xlink{margin-left:auto;color:var(--sol);font-size:11px;text-decoration:none;font-family:'Space Mono',monospace;}
.xlink:hover{color:var(--sol2);}

.empty{text-align:center;padding:32px;color:var(--muted);font-family:'Space Mono',monospace;font-size:12px;background:var(--card);border:1px solid var(--border);border-radius:12px;}

footer{margin-top:56px;text-align:center;font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);}
footer span{color:var(--sol2);}

@media(max-width:500px){.grid{grid-template-columns:1fr 1fr;} .sv{font-size:20px;}}
</style>
</head>
<body>
<div class="orb"></div>
<div class="wrap">

<header>
  <div class="logo">SV</div>
  <div class="brand"><h1>SolView</h1><p>Solana Portfolio Tracker</p></div>
  <div class="badge">MAINNET</div>
</header>

<div class="sbox">
  <div class="slabel">Wallet Address</div>
  <div class="srow">
    <input id="inp" type="text" placeholder="Masukkan Solana wallet address..."/>
    <button class="btn" id="trackBtn" onclick="go()">Track →</button>
  </div>
  <div class="demos">
    <span>Try:</span>
    <div class="chip" onclick="demo('vines1vzrYbzLMRdu58ou5XTby4qAqVRLmqo36NKPTg')">Vines</div>
    <div class="chip" onclick="demo('GThUX1Atko4tqhN2NaiTazWSeFWMuiUvfFnyJyUghFMJ')">Demo 2</div>
    <div class="chip" onclick="demo('9WzDXwBbmkg8ZTbNMqUxvQRAyrZzDsGYdLVL9zYtAWWM')">Demo 3</div>
  </div>
</div>

<div class="err" id="err"></div>

<div class="loading" id="load">
  <div class="spin"></div>
  <p id="lmsg">Menghubungkan ke Solana...</p>
</div>

<div id="dash">
  <div class="whead">
    <div class="wav" id="wav">?</div>
    <div class="winfo"><h2>Solana Wallet</h2><div class="waddr" id="waddr">—</div></div>
    <button class="rbtn" onclick="go()" title="Refresh">↻</button>
  </div>

  <div class="grid">
    <div class="sc"><div class="slb">SOL Balance</div><div class="sv g" id="solbal">—</div><div class="ss" id="solusd">≈ $—</div></div>
    <div class="sc"><div class="slb">Tokens</div><div class="sv" id="tokcnt">—</div><div class="ss">SPL tokens</div></div>
    <div class="sc"><div class="slb">Transactions</div><div class="sv" id="txcnt">—</div><div class="ss">Recent</div></div>
  </div>

  <div class="sec">
    <div class="stitle">Token Holdings</div>
    <div class="tlist" id="tlist"></div>
  </div>

  <div class="sec">
    <div class="stitle">Recent Transactions</div>
    <div class="xlist" id="xlist"></div>
  </div>
</div>

<footer>Built with ❤️ on <span>Solana</span> · SolView v2.0 · Superteam Grant Project</footer>
</div>

<script>
// ─── Helpers ──────────────────────────────────────────────────────
function setLoading(on, msg) {
  document.getElementById('load').style.display = on ? 'block' : 'none';
  document.getElementById('dash').style.display = on ? 'none' : 'block';
  document.getElementById('trackBtn').disabled = on;
  if (msg) document.getElementById('lmsg').textContent = msg;
}
function showErr(html) {
  const el = document.getElementById('err');
  el.innerHTML = html; el.style.display = 'block';
}
function hideErr() { document.getElementById('err').style.display = 'none'; }

function demo(addr) { document.getElementById('inp').value = addr; go(); }

async function ft(url, opts, ms = 9000) {
  const c = new AbortController();
  const t = setTimeout(() => c.abort(), ms);
  try {
    const r = await fetch(url, { ...opts, signal: c.signal });
    clearTimeout(t); return r;
  } catch(e) { clearTimeout(t); throw e; }
}

// ─── RPC (multiple fallback) ───────────────────────────────────────
const RPCS = [
  'https://rpc.ankr.com/solana',
  'https://api.mainnet-beta.solana.com',
  'https://solana-api.projectserum.com',
];
async function rpc(method, params) {
  for (const url of RPCS) {
    try {
      const r = await ft(url, {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({jsonrpc:'2.0',id:1,method,params})
      }, 8000);
      const j = await r.json();
      if (j.result !== undefined) return j.result;
    } catch { continue; }
  }
  return null;
}

// ─── SOL Price ────────────────────────────────────────────────────
async function getPrice() {
  try {
    const r = await ft('https://api.coingecko.com/api/v3/simple/price?ids=solana&vs_currencies=usd', {}, 6000);
    const d = await r.json();
    if (d?.solana?.usd) return d.solana.usd;
  } catch {}
  try {
    const r = await ft('https://price.jup.ag/v6/price?ids=So11111111111111111111111111111111111111112', {}, 6000);
    const d = await r.json();
    const p = Object.values(d?.data || {})[0]?.price;
    if (p) return p;
  } catch {}
  return 0;
}

// ─── Main ─────────────────────────────────────────────────────────
async function go() {
  const addr = document.getElementById('inp').value.trim();
  if (!addr) { showErr('⚠ Masukkan wallet address terlebih dahulu.'); return; }
  if (!/^[1-9A-HJ-NP-Za-km-z]{32,44}$/.test(addr)) {
    showErr('⚠ Format tidak valid. Gunakan alamat Solana yang benar (32–44 karakter base58).'); return;
  }
  hideErr();
  setLoading(true, 'Menghubungkan ke Solana...');

  // ── SOL Balance ──
  setLoading(true, 'Mengambil SOL balance...');
  const balRaw = await rpc('getBalance', [addr]);
  const solBal = balRaw === null ? 0 :
    (typeof balRaw === 'number' ? balRaw : (balRaw?.value ?? 0)) / 1e9;

  // ── SOL Price ──
  setLoading(true, 'Mengambil harga SOL...');
  const price = await getPrice();

  // ── Tokens ──
  setLoading(true, 'Mengambil token holdings...');
  let tokens = [];
  const tokRaw = await rpc('getTokenAccountsByOwner', [
    addr,
    { programId: 'TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA' },
    { encoding: 'jsonParsed' }
  ]);
  if (tokRaw?.value) {
    tokens = tokRaw.value
      .filter(t => parseFloat(t.account?.data?.parsed?.info?.tokenAmount?.uiAmountString || '0') > 0)
      .map(t => {
        const info = t.account.data.parsed.info;
        return {
          mint: info.mint,
          amount: parseFloat(info.tokenAmount.uiAmountString),
          decimals: info.tokenAmount.decimals
        };
      });
  }

  // ── Transactions ──
  setLoading(true, 'Mengambil transaksi...');
  let txs = [];
  const sigRaw = await rpc('getSignaturesForAddress', [addr, { limit: 10 }]);
  if (Array.isArray(sigRaw)) txs = sigRaw;

  // ── Render ──
  document.getElementById('wav').textContent = addr[0].toUpperCase();
  document.getElementById('waddr').textContent = addr.slice(0,10) + '...' + addr.slice(-8);
  document.getElementById('solbal').textContent = solBal.toFixed(4) + ' SOL';
  document.getElementById('solusd').textContent = price
    ? '≈ $' + (solBal * price).toLocaleString('en-US',{maximumFractionDigits:2})
    : '≈ harga tidak tersedia';
  document.getElementById('tokcnt').textContent = tokens.length;
  document.getElementById('txcnt').textContent = txs.length;

  // Tokens
  const tlist = document.getElementById('tlist');
  if (!tokens.length) {
    tlist.innerHTML = '<div class="empty">Tidak ada SPL token ditemukan.</div>';
  } else {
    tlist.innerHTML = tokens.slice(0,20).map(t => {
      const sym = t.mint.slice(0,4).toUpperCase();
      return `<div class="trow">
        <div class="ticon">${sym.slice(0,3)}</div>
        <div style="flex:1;min-width:0">
          <div class="tname">${sym}•••</div>
          <div class="tmint">${t.mint.slice(0,8)}...${t.mint.slice(-6)}</div>
        </div>
        <div class="tamt">
          <div class="tamtv">${t.amount.toLocaleString()}</div>
          <div class="tvlink"><a href="https://solscan.io/token/${t.mint}" target="_blank">View ↗</a></div>
        </div>
      </div>`;
    }).join('');
  }

  // Transactions
  const xlist = document.getElementById('xlist');
  if (!txs.length) {
    xlist.innerHTML = '<div class="empty">Tidak ada transaksi ditemukan.</div>';
  } else {
    xlist.innerHTML = txs.map(tx => {
      const sig = tx.signature;
      const time = tx.blockTime ? new Date(tx.blockTime*1000).toLocaleString('id-ID') : '—';
      const ok = !tx.err;
      return `<div class="xrow">
        <div class="xdot ${ok?'ok':'fail'}"></div>
        <div style="flex:1;min-width:0">
          <div class="xsig">${sig.slice(0,14)}...${sig.slice(-6)}</div>
          <div class="xtime">${time}</div>
        </div>
        <a class="xlink" href="https://solscan.io/tx/${sig}" target="_blank">View ↗</a>
      </div>`;
    }).join('');
  }

  // Jika semua data null (berarti RPC gagal semua)
  if (balRaw === null && !tokens.length && !txs.length) {
    setLoading(false);
    document.getElementById('dash').style.display = 'none';
    showErr(
      '⚠ <b>Tidak bisa terhubung ke Solana RPC.</b><br><br>' +
      'Ini biasanya terjadi karena:<br>' +
      '• Koneksi internet lemah atau terputus<br>' +
      '• RPC sedang down sementara<br><br>' +
      '✅ <b>Solusi:</b> Tunggu 30 detik lalu coba lagi, atau deploy file ini ke ' +
      '<a href="https://netlify.com/drop" target="_blank" style="color:var(--sol)">netlify.com/drop</a> ' +
      'dan buka dari sana.'
    );
    return;
  }

  setLoading(false);
}

document.getElementById('inp').addEventListener('keydown', e => {
  if (e.key === 'Enter') go();
});
</script>
</body>
</html>
